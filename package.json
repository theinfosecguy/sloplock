{
  "name": "sloplock",
  "version": "0.1.0",
  "description": "Block nonexistent and too-new package dependencies before they enter your repo.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theinfosecguy/sloplock.git"
  },
  "bugs": {
    "url": "https://github.com/theinfosecguy/sloplock/issues"
  },
  "homepage": "https://github.com/theinfosecguy/sloplock#readme",
  "publishConfig": {
    "provenance": true
  },
  "bin": {
    "sloplock": "dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/core/index.js"
  },
  "files": [
    "dist",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "clean": "rm -rf dist coverage",
    "build": "npm run clean && tsc -p tsconfig.json && node -e \"require('node:fs').chmodSync('dist/cli/index.js', 0o755)\" && npm run bundle:action",
    "bundle:action": "esbuild src/action/index.ts --bundle --platform=node --target=node24 --format=cjs --sourcemap --outfile=dist/action/index.cjs --banner:js='// Bundled action entrypoint. Do not edit directly.'",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:dist-policy": "node scripts/check-dist-pr-policy.mjs --base origin/main",
    "check:dist-current": "node scripts/check-dist-current.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "smoke:package": "node scripts/smoke-package.mjs",
    "smoke:ecosystems": "node scripts/smoke-ecosystems.mjs"
  },
  "keywords": [
    "supply-chain",
    "github-action",
    "crates",
    "go",
    "maven",
    "jvm",
    "gradle",
    "nuget",
    "npm",
    "composer",
    "packagist",
    "php",
    "pypi",
    "rubygems",
    "ruby",
    "bundler",
    "rust",
    "python",
    "security",
    "dependencies"
  ],
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@commander-js/extra-typings": "^15.0.0",
    "commander": "^15.0.0",
    "saxes": "^6.0.0",
    "smol-toml": "^1.7.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@eslint/js": "^9.30.0",
    "@types/node": "^24.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.30.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.1.9"
  }
}
